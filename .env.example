# Format: postgres://username:password@host:port/database?sslmode=require
DATABASE_URL=""

# Do not use quotes for the values below.

# OpenAI (used for the explain feature with agentic search)
OPENAI_API_KEY=
# Optional. Default: gpt-5.4-mini
OPENAI_MODEL=gpt-5.4-mini
# Optional. One of: minimal, low, medium, high. Default: high
OPENAI_REASONING_EFFORT=high

# Exa AI (used as the search tool the model can call)
EXA_API_KEY=
# Optional. Exa search type. Common values: auto, fast, instant, deep-lite, deep, deep-reasoning. Default: auto
EXA_SEARCH_TYPE=auto
# Optional. Maximum number of search calls the model can make per explanation. Default: 10
EXPLAIN_MAX_SEARCHES=10
# Optional. Number of results returned per Exa search query (1-100). Default: 5
EXPLAIN_RESULTS_PER_SEARCH=5
# Optional. Per-result text character cap returned by Exa. Default: 35000
EXPLAIN_MAX_CHARS=35000
# Optional. Log search queries, result titles/URLs, and small text/output previews. Set false to disable. Default: true
EXPLAIN_TRACE_LOGS=true
# Optional. Max characters for each logged preview. Default: 260
EXPLAIN_LOG_SNIPPET_CHARS=260
# Optional. Override the explanation system prompt as a single-line string.
# EXPLAIN_SYSTEM_PROMPT=
